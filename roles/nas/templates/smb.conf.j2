[global]
   workgroup = WORKGROUP
   server string = Hobbit Media Server
   security = user
   map to guest = Never

   # Bind only to LAN + loopback (required for smbpasswd)
   interfaces = 127.0.0.1 {{ lan_interface }}
   bind interfaces only = yes

   # LAN-only access
   hosts allow = 127.0.0.1 {{ lan_subnet }}
   hosts deny = 0.0.0.0/0

   # Modern protocol only (SMB2+, no legacy SMB1)
   server min protocol = SMB2
   server max protocol = SMB3

   # Require signing for integrity
   server signing = mandatory

   # Logging
   log file = /var/log/samba/log.%m
   max log size = 50

[media]
   path = /media/hobbit
   browseable = yes
   read only = no
   valid users = hobbit
   create mask = 0644
   directory mask = 0755
