[global]
   workgroup = WORKGROUP
   server string = Hobbit Media Server
   security = user
   map to guest = Bad User
   log file = /var/log/samba/log.%m
   max log size = 50

[media]
   path = /media/hobbit
   browseable = yes
   read only = yes
   guest ok = yes
   write list = hobbit
   create mask = 0644
   directory mask = 0755
